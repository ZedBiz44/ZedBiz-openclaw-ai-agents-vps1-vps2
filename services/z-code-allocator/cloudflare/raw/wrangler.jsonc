{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zedbiz-zcode-db-emergency",
  "main": "src/index.js",
  "compatibility_date": "2026-07-21",
  "workers_dev": true,
  "preview_urls": false,
  "routes": [
    { "pattern": "zcode-db.zbiz.ca", "custom_domain": true }
  ],
  "vars": {
    "ORIGIN_BASE": "https://edith.zbiz.ca/_zedbiz-zcode-db/"
  }
}
